# Principe — environment variables for docker compose.
#
# Copy this file to .env.runtime (gitignored), fill in the values, and
# `docker compose up` will pick them up. The bin/start.sh wrapper does
# this for you on first boot (generates strong random secrets).

# ─── Secrets (generated on first boot by bin/start.sh) ────────────────

# 32-byte hex string shared between the web app and the Statistician.
# Both services HMAC their requests with this. Rotate by deleting it +
# rebooting; the next boot generates a fresh one.
STATISTICIAN_SHARED_SECRET=

# 32-byte hex string used to derive the encryption key for stored
# API keys (Anthropic). Rotation requires re-entering all stored
# keys through the wizard.
PRINCIPE_ENCRYPTION_KEY=

# ─── Database (defaults are fine for the bundled Postgres) ────────────

# Override only if you want a stronger password than the default
# "principe". The bundled Postgres is on the docker network only.
POSTGRES_PASSWORD=principe

# ─── Web app ──────────────────────────────────────────────────────────

# Public port. Change if 3000 is taken on your host.
WEB_PORT=3000

# Origin used by WebAuthn for passkey ceremonies. MUST match the URL
# your browser uses to reach Principe. Change to https://your-domain
# when you put a reverse proxy in front.
WEBAUTHN_ORIGIN=http://localhost:3000

# ─── Knowledge updates (optional, off by default) ──────────────────────

# Príncipe ships in LOCAL mode: no remote checks, only the bundled
# calibration corpus. To subscribe to signed pull-updates, set BOTH the
# URL and the matching public key — the URL alone verifies nothing.
#
# Official daily feed (distilled from public cybersecurity sources):
# PRINCIPE_UPDATES_URL=https://github.com/omergrossman/principe-feed/releases/download/latest
# PRINCIPE_UPDATES_PUBLIC_KEY=56c8813a7d455b4ec58dd45d0befd6920438f4f37a6836f1542d7f2a730606b8
#
# Other values for PRINCIPE_UPDATES_URL:
#   <your own URL>   → publish + serve your own signed bundles (set your own key below)
#   "disabled"       → hide the updates UI entirely; explicit opt-out
#   "" or unset      → LOCAL mode (default): shipped calibration only
#
# PRINCIPE_UPDATES_PUBLIC_KEY must be 32 bytes hex (64 chars). The key
# baked into the build is an all-zeros PLACEHOLDER, so a real key here is
# required for ANY remote feed. Generate your own with:
#   pnpm tsx scripts/generate-keypair.ts
