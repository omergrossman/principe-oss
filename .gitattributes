# Ensure shell scripts and other files that run inside Linux containers
# always have LF line endings, regardless of the client OS.
*.sh        text eol=lf
Dockerfile* text eol=lf
*.ps1       text eol=crlf
*.py        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
